# Copy this file to .env (root) before docker compose deploy.
# Do not commit your real .env with secrets.

# Global runtime mode
NODE_ENV=production

# Public URLs
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api
FRONTEND_URL=https://app.example.com

# JWT (at least 32 chars)
JWT_SECRET=replace-with-strong-random-secret-at-least-32-characters

# Mongo root credentials used by docker-compose internal MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=replace-with-strong-password

# Redis password used by docker-compose internal Redis
REDIS_PASSWORD=replace-with-strong-password

# Optional SMTP settings (leave empty to disable email sending in many flows)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Optional Cloudinary media upload settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
