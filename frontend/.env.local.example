# Public client-side URL of backend API
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Public URL of this frontend app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional app name used in UI metadata
NEXT_PUBLIC_APP_NAME=SoulSupport

# Server-side URL for Next.js route handlers (recommended in production)
# Example (Docker compose): API_URL=http://backend:5007/api
API_URL=http://localhost:5000/api

# AI/chat provider key for /api/chat route
OPENROUTER_API_KEY=replace-me

# n8n Aurabot webhook URL for mental health chatbot
# Replace with your n8n production webhook URL
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678/webhook/aurabot
