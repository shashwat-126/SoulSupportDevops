{
  "id": null,
  "uid": "soulsupport-main",
  "title": "SoulSupport Dashboard",
  "tags": ["soulsupport"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Backend Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"soulsupport-backend\"}",
          "legendFormat": "Backend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "soulsupport_active_users_total",
          "legendFormat": "Users"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "steps": [{ "value": null, "color": "blue" }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Therapists",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "soulsupport_active_therapists_total",
          "legendFormat": "Therapists"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "steps": [{ "value": null, "color": "purple" }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Verified Therapists",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "soulsupport_verified_therapists_total",
          "legendFormat": "Verified"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "steps": [{ "value": null, "color": "green" }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "soulsupport_sessions_total{status=\"all\"}",
          "legendFormat": "Sessions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "steps": [{ "value": null, "color": "orange" }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Total Reviews",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "soulsupport_reviews_total",
          "legendFormat": "Reviews"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "thresholds": { "steps": [{ "value": null, "color": "yellow" }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Sessions by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        { "expr": "soulsupport_sessions_total{status=\"completed\"}", "legendFormat": "Completed" },
        { "expr": "soulsupport_sessions_total{status=\"pending\"}", "legendFormat": "Pending" },
        { "expr": "soulsupport_sessions_total{status=\"cancelled\"}", "legendFormat": "Cancelled" }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "id": 8,
      "title": "Forum Posts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "soulsupport_forum_posts_total",
          "legendFormat": "Posts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "semi-dark-blue" },
          "thresholds": { "steps": [{ "value": null, "color": "semi-dark-blue" }] }
        }
      }
    },
    {
      "id": 9,
      "title": "Published Resources",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "soulsupport_resources_total",
          "legendFormat": "Resources"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "semi-dark-green" },
          "thresholds": { "steps": [{ "value": null, "color": "semi-dark-green" }] }
        }
      }
    },
    {
      "id": 10,
      "title": "Pending vs Verified Therapists",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 4 },
      "targets": [
        { "expr": "soulsupport_verified_therapists_total", "legendFormat": "Verified" },
        { "expr": "soulsupport_active_therapists_total - soulsupport_verified_therapists_total", "legendFormat": "Pending Verification" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Pending Verification" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      }
    },
    {
      "id": 11,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 12,
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        }
      }
    },
    {
      "id": 13,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 14,
      "title": "Node.js Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"soulsupport-backend\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"soulsupport-backend\"}",
          "legendFormat": "Heap Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "bytes"
        }
      }
    },
    {
      "id": 15,
      "title": "Active Alerts",
      "type": "alertlist",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "options": {
        "showOptions": "current",
        "maxItems": 20,
        "sortOrder": 1,
        "alertName": "",
        "dashboardAlerts": false,
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": true,
          "normal": false,
          "error": true
        }
      }
    }
  ],
  "schemaVersion": 39
}
